# ─────────────────────────────────────────────────────────────
#  Instagram-Clone — Root .gitignore
#  Covers: Python microservices, React/Vite frontend,
#          gRPC generated files, Docker infra, JWT keys
# ─────────────────────────────────────────────────────────────


# ── Python ────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
*.pyd

# Distribution / packaging
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# Installer logs
pip-log.txt
pip-delete-this-directory.txt

# Unit test / coverage reports
htmlcov/
.tox/
.nox/
.coverage
.coverage.*
coverage.xml
*.cover
*.py,cover
.hypothesis/
.pytest_cache/
cover/

# Type checking / linting caches
.mypy_cache/
.ruff_cache/
.pytype/
.dmypy.json
dmypy.json

# PyInstaller
*.manifest
*.spec

# Jupyter / IPython
*.ipynb_checkpoints
profile_default/
ipython_config.py

# PyBuilder
.pybuilder/
target/

# Sphinx docs
doc/_build/
docs/_build/

# Translations
*.mo
*.pot

# Django leftovers (just in case)
local_settings.py
db.sqlite3
db.sqlite3-journal

# ── Virtual Environments ──────────────────────────────────────
.venv/
venv/
ENV/
env/
.env.bak

# ── Environment & Secrets ─────────────────────────────────────
.env
.env.*
!.env.example

# Per-service .env files (explicit)
Authentication-Server/.env
User-Service/.env
chat-server/.env
Notification-Server/.env

# ── JWT / Cryptographic Keys ──────────────────────────────────
shared/keys/jwt_private_key.pem
shared/keys/jwt_public_key.pem
*.pem
*.key
*.crt
*.p12
*.pfx

# ── gRPC Generated Files ──────────────────────────────────────
# Protobuf-generated stubs — regenerate with `python -m grpc_tools.protoc`
*_pb2.py
*_pb2_grpc.py
*_pb2.pyi

# ── Node / Frontend ───────────────────────────────────────────
node_modules/
insta-frontend/dist/
insta-frontend/dist-ssr/
*.local

# Vite cache
insta-frontend/.vite/

# ── Logs ──────────────────────────────────────────────────────
*.log
*.log.*
logs/

# ── MinIO Object Storage ──────────────────────────────────────
Mini-o/storage/

# ── Docker volumes & runtime data ────────────────────────────
# Kafka persistent data volumes
Kafka-Server/data/
Kafka-Server/logs/

# Redis persistent data
Redis-Server/data/

# ── Miscellaneous Config / Notes ──────────────────────────────
# Local server address notes — keep out of VCS
servers_ip_port.txt
insta-frontend/phone_auth.txt

# ── IDEs & Editors ────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
*.swn
.project
.pydevproject
.settings/
*.sublime-project
*.sublime-workspace

# ── OS Files ──────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini
